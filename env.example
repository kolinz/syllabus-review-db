# ===========================
# サーバー設定
# ===========================

# サーバーが待ち受けるポート番号
PORT=3000

# JWTトークン署名用シークレットキー（本番環境では必ず強力な文字列に変更すること）
JWT_SECRET=your-secret-key-here

# JWTトークンの有効期限（例: 24h, 7d, 30m）
JWT_EXPIRES_IN=24h

# ===========================
# PDFストレージ設定
# ===========================

# PDFファイルの保存ディレクトリ（絶対パスまたはserver.jsからの相対パス）
PDF_UPLOAD_DIR=./uploads

# PDFファイルの最大サイズ（MB単位）
PDF_MAX_SIZE_MB=5

# ===========================
# コマシラバス設定
# ===========================

# コマシラバスの最大回数（通常は15）
KOMA_MAX_SESSION=15

# ===========================
# データベース設定
# ===========================

# SQLiteデータベースファイルのパス（server.jsからの相対パス）
DB_PATH=./syllabus-review.db

# ===========================
# 開発用設定
# ===========================

# true にするとサンプルデータを投入する（開発・デモ用途）
# 本番環境では必ず false に設定すること
SEED_SAMPLE_DATA=false
